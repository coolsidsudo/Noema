# Copy to deploy/reference-single-node/config/reference.env and adjust absolute paths.

# Absolute path to repository root on operator host.
NOEMA_REPO_ROOT=/srv/noema

# Absolute path for continuity-aware deployment-local state.
NOEMA_STATE_ROOT=/srv/noema-state

# Optional host ports.
NOEMA_HUMAN_PORT=8080
NOEMA_AGENT_PORT=8787
